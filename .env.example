# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Graphiti (Neo4j) 지식 그래프 설정 =====
# 로컬 Neo4j docker: docker compose -f graphiti-db/docker-compose.yml up -d
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish-dev

# Graphiti LLM 모델 (옵션) — 기본 provider=openai, model=gpt-4o-mini.
# OpenAI Tier 1 TPM 한도(200k) 우회하려면 anthropic provider 사용.
# GRAPHITI_PROVIDER=openai            # 'openai' | 'anthropic'
# GRAPHITI_MODEL=gpt-4o-mini          # provider별 기본: openai=gpt-4o-mini, anthropic=claude-haiku-4-5
# GRAPHITI_SMALL_MODEL=gpt-4o-mini    # 기본은 main model과 동일
# GRAPHITI_LLM_BASE_URL=              # LLM_BASE_URL과 다른 엔드포인트 쓸 때만 (anthropic 경로에서는 무시)

# Anthropic 경로용 (GRAPHITI_PROVIDER=anthropic 일 때 필요).
# embeddings는 OpenAI text-embedding-3-small 그대로 사용 (Tier 1에서도 1M TPM이라 영향 없음)
# 이므로 ANTHROPIC_API_KEY 와 별도로 OpenAI key (LLM_API_KEY)는 항상 필요.
# ANTHROPIC_API_KEY=sk-ant-...

# ===== Zep Cloud (선택 / legacy) =====
# 기본 Graphiti 경로에서는 불필요. 복귀 시 `uv sync --extra zep` + 아래 키 설정.
# ZEP_API_KEY=your_zep_api_key_here
# ZEP_BASE_URL=  # 자체 호스팅(CE)일 때만

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here